{
  "name": "@sr/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./dist/constants/index.js"
    },
    "./promql": {
      "types": "./src/promql/index.ts",
      "default": "./dist/promql/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
}
