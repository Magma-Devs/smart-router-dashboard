# EditorConfig — https://editorconfig.org
# Top-most EditorConfig file for the smart-router-dashboard monorepo.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,markdown}]
# Preserve trailing whitespace in Markdown (two spaces = hard line break).
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
