# Shared dev image — has the workspace deps baked in (pnpm install at build
# time), so the dev compose can mount only source/dist dirs without clobbering
# node_modules. Mirrors lava-connect's Dockerfile.dev.
FROM node:24-alpine
RUN corepack enable
WORKDIR /app

# Install deps against the lockfile so the image carries node_modules for all
# workspace packages. Source is mounted at runtime by docker-compose.dev.yml.
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile

# Build shared + db once so api/web have a dist to resolve before the watcher warms.
COPY packages/shared/ packages/shared/
COPY packages/db/ packages/db/
RUN pnpm --filter @sr/shared build && pnpm --filter @sr/db build

# Default command is overridden per-service in docker-compose.dev.yml.
CMD ["sh"]
