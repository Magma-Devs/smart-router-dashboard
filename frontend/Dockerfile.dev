# Development Dockerfile with hot reloading
FROM node:22-alpine AS builder

RUN corepack enable

WORKDIR /app

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install

# Copy source (will be overridden by volume mount)
COPY . .

# Expose port
EXPOSE 3000

# Run in development mode with hot reloading
# --hostname 0.0.0.0 allows external connections
# --turbo enables turbopack for faster rebuilds
CMD ["pnpm", "dev", "--hostname", "0.0.0.0", "--turbo"]

