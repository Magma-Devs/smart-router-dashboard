# =============================================================================
# Smart Router Dashboard — example environment
# =============================================================================
# Copy to `.env` and adjust. EVERY variable here has a working default in the
# compose files, so for a local `make up` you don't strictly need this file —
# it's the reference for self-hosting one image against your own router.
#
# Source of truth: apps/api/src/config.ts (api) + CLAUDE.md env-var tables.
# Auth-only variables are ignored unless AUTH_MODE=enabled.
# -----------------------------------------------------------------------------


# --- API (apps/api) ----------------------------------------------------------

API_PORT=8000
API_HOST=0.0.0.0

# Prometheus the api proxies. Compose sets this to http://prometheus:9090.
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT_MS=10000

# Comma list or JSON array of allowed origins. Unset = allow all.
# CORS_ORIGINS=http://localhost:3000

# Per-IP-per-minute rate limit on the api.
RATE_LIMIT_MAX=300

# Directory holding the router values file at <dir>/core/values.yml
# (either helm-values or raw SR_CONFIG format).
HELM_VALUES_DIR=/app/helm-values

LOG_LEVEL=info

# Build provenance surfaced by GET /version (usually injected by CI).
# GIT_COMMIT=unknown
# APP_VERSION=0.0.0

# development enables /docs (Swagger) + pretty logs. Default: production.
NODE_ENV=production


# --- Authentication (only read when AUTH_MODE=enabled) -----------------------
# With AUTH_MODE=disabled (default) there is NO login and NO database.

AUTH_MODE=disabled

# HS256 signing secret. MUST be identical on api and web.
#   openssl rand -base64 32
# AUTH_SECRET=

# Postgres connection string for the users table (AUTH_MODE=enabled only).
# DATABASE_URL=postgres://user:pass@localhost:5432/sr_dashboard

# Idempotent bootstrap-admin seed created on first boot.
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=change-me

# OAuth providers — each button appears only when its id+secret pair is set.
# The api additionally validates the `aud` claim of Google ID tokens.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=


# --- Web (apps/web) ----------------------------------------------------------

# Baked into the browser bundle at BUILD time.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LOCAL_MODE=false

# RUNTIME overrides read per-request by GET /api/config, so one published image
# can serve any host without a rebuild.
# DASHBOARD_API_URL=http://localhost:8000
# DASHBOARD_LOCAL_MODE=false
# DASHBOARD_GRAFANA_URL=http://localhost:3001

# Server-side api URL for Auth.js callbacks (compose sets http://api:8000).
# INTERNAL_API_BASE_URL=http://localhost:8000


# --- Compose / Makefile knobs ------------------------------------------------

# THE values file — mounted into the router as its config AND into the api as
# helm-values, so the dashboard always reflects the running topology.
SR_CONFIG_HOST=./dev-config/values.yml

# router-profile build context (a smart-router checkout).
# ROUTER_DIR=../../smart-router
# SR_SPEC=specs/
# SR_LOG_LEVEL=info
# SR_LOG_FORMAT=json
